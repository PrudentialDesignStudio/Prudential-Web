# Admin password for the dashboard
ADMIN_PASSWORD=pis-admin-2024

# Secret key for JWT tokens — change this to a long random string
ADMIN_JWT_SECRET=change-this-to-a-long-random-secret-key

# Port the backend runs on
PORT=3001

# Path to SQLite database file (optional — defaults to ./data/pis.db)
# DB_PATH=/path/to/pis.db

# ── Admissions / Email ──────────────────────────────────────────────────────
# Gmail address used to send admission PDFs to the school
GMAIL_USER=your-gmail@gmail.com

# Gmail App Password (NOT your regular Gmail password).
# To generate one:
#   1. Go to myaccount.google.com → Security → 2-Step Verification (enable it)
#   2. Then go to myaccount.google.com/apppasswords
#   3. Create a new app password — select "Mail" and "Other (Custom name)" → "PIS Admissions"
#   4. Copy the 16-character password (no spaces) and paste it here
GMAIL_PASS=your-16-char-app-password

# Email address where new admission PDFs are sent (can be same as GMAIL_USER)
NOTIFY_EMAIL=admissions@your-school.com

# Directory to store generated admission PDFs (optional)
# Defaults to /tmp/pis-admissions in production, ./data/generated locally
# PDF_DIR=/app/data/generated
